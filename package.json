{
  "name": "voltX",
  "version": "1.0.0",
  "description": "A modern, production-ready CLI toolkit for Windows (Node.js, ESM)",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "voltX": "bin/voltx.js"
  },
  "scripts": {
    "start": "node bin/voltx.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/mycli.exe"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "conf": "^10.2.1",
    "execa": "^8.0.1",
    "figlet": "^1.7.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.16",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "pkg": "^6.3.0"
  },
  "keywords": ["cli", "windows", "commander", "chalk", "ora", "figlet", "conf", "execa", "fs-extra", "inquirer", "axios"],
  "author": "Your Name",
  "license": "MIT"
}
